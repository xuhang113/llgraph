# llgraph 专用 API 凭据（OpenAI 兼容网关；与 Claude CLI / ANTHROPIC_* 无关）
# 安装: cp llgraph.env.example ~/.config/llgraph/llgraph.env 后编辑

LLGRAPH_API_BASE_URL=https://your-ai-gateway.example
LLGRAPH_API_KEY=your-llgraph-api-token
LLGRAPH_MODEL=claude-opus-4-6

# Tavily Web 搜索（/web on 启用；免费 1000 credits/月，见 https://docs.tavily.com/documentation/api-credits）
TAVILY_API_KEY=tvly-your-api-key
